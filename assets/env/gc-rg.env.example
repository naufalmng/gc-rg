# GC-RG runtime config
# Copy to /etc/gc-rg/gc-rg.env on Linux or gc-rg.env beside binaries on Windows.

# SMTP provider: gmail, yahoo, outlook, or custom.
GC_RG_EMAIL_PROVIDER=gmail

# Provider defaults fill host/port/tls for gmail/yahoo/outlook.
# Custom provider must set these explicitly.
GC_RG_SMTP_HOST=
GC_RG_SMTP_PORT=587
GC_RG_SMTP_TLS=starttls
GC_RG_SMTP_AUTH=on

# Use provider app password when available. Gmail/Yahoo require app password.
GC_RG_SMTP_USERNAME=your-email@gmail.com
GC_RG_SMTP_PASSWORD=replace-with-app-password

GC_RG_EMAIL_FROM=your-email@gmail.com
GC_RG_EMAIL_TO=ops@example.com,manager@example.com
GC_RG_EMAIL_CC=
GC_RG_EMAIL_SUBJECT_PREFIX=[GC-RG]

# Optional scheduler defaults used by templates/scripts.
GC_RG_REPORT_DIR=/opt/gc-rg/reports/daily
GC_RG_WORKDIR=/opt/gc-rg
